@model TicketEditViewModel

@{
    ViewData["Title"] = "Edit Ticket";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-7">

        <!-- Header -->
        <div class="d-flex align-items-center gap-2 mb-4">
            <a asp-action="Details" asp-route-id="@Model.Input.TicketId"
               class="btn btn-sm btn-light border">
                <i class="bi bi-arrow-left"></i>
            </a>
            <div>
                <h5 class="mb-0 fw-semibold">Edit Ticket #@Model.Input.TicketId</h5>
                <p class="text-muted small mb-0">Update ticket details</p>
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">

                <!-- Validation Summary -->
                <div asp-validation-summary="ModelOnly"
                     class="alert alert-danger small py-2 mb-4"></div>

                <form asp-action="Edit" asp-route-id="@Model.Input.TicketId" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Input.TicketId" />

                    <!-- Title -->
                    <div class="mb-3">
                        <label asp-for="Input.Title" class="form-label small fw-medium">
                            Title <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Input.Title" class="form-control" />
                        <span asp-validation-for="Input.Title"
                              class="text-danger small"></span>
                    </div>

                    <!-- Description -->
                    <div class="mb-3">
                        <label asp-for="Input.Description"
                               class="form-label small fw-medium">
                            Description <span class="text-danger">*</span>
                        </label>
                        <textarea asp-for="Input.Description"
                                  class="form-control" rows="4"></textarea>
                        <span asp-validation-for="Input.Description"
                              class="text-danger small"></span>
                    </div>

                    <!-- Category + Priority -->
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="Input.CategoryId"
                                   class="form-label small fw-medium">
                                Category <span class="text-danger">*</span>
                            </label>
                            <select asp-for="Input.CategoryId"
                                    asp-items="Model.Categories"
                                    class="form-select">
                                <option value="">-- Select Category --</option>
                            </select>
                            <span asp-validation-for="Input.CategoryId"
                                  class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Input.Priority"
                                   class="form-label small fw-medium">
                                Priority <span class="text-danger">*</span>
                            </label>
                            <select asp-for="Input.Priority" class="form-select">
                                <option value="">-- Select Priority --</option>
                                <option value="Low">🟢 Low</option>
                                <option value="Medium">🟡 Medium</option>
                                <option value="High">🟠 High</option>
                                <option value="Critical">🔴 Critical</option>
                            </select>
                            <span asp-validation-for="Input.Priority"
                                  class="text-danger small"></span>
                        </div>
                    </div>

                    <!-- Status + Assign To -->
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="Input.Status"
                                   class="form-label small fw-medium">
                                Status <span class="text-danger">*</span>
                            </label>
                            <select asp-for="Input.Status" class="form-select">
                                <option value="Open">Open</option>
                                <option value="InProgress">In Progress</option>
                                <option value="Resolved">Resolved</option>
                                <option value="Closed">Closed</option>
                            </select>
                            <span asp-validation-for="Input.Status"
                                  class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Input.AssignedToId"
                                   class="form-label small fw-medium">
                                Assign To
                                <span class="text-muted fw-normal">(optional)</span>
                            </label>
                            <select asp-for="Input.AssignedToId"
                                    asp-items="Model.AssignableUsers"
                                    class="form-select">
                                <option value="">-- Leave Unassigned --</option>
                            </select>
                        </div>
                    </div>

                    <!-- Due Date -->
                    <div class="mb-4">
                        <label asp-for="Input.DueDate" class="form-label small fw-medium">
                            Due Date
                            <span class="text-muted fw-normal">(SLA deadline)</span>
                        </label>
                        <input asp-for="Input.DueDate" type="datetime-local" step="60" class="form-control" />
                        <span asp-validation-for="Input.DueDate"
                              class="text-danger small"></span>
                        @if (Model.Input.DueDate < DateHelper.ToCairoTime(DateTime.UtcNow) && Model.Input.Status != TicketStatus.Resolved && Model.Input.Status != TicketStatus.Closed)
                        {
                            <small class="text-danger d-block mt-1">
                                <i class="bi bi-exclamation-triangle"></i> This ticket has breached its SLA deadline.
                            </small>
                        }
                    </div>

                    <!-- Actions -->
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-check-lg me-1"></i> Save Changes
                        </button>
                        <a asp-action="Details" asp-route-id="@Model.Input.TicketId"
                           class="btn btn-outline-secondary px-4">
                            Cancel
                        </a>
                    </div>

                </form>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}