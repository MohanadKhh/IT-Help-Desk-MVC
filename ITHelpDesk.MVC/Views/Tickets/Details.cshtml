@model TicketDto

@{
    ViewData["Title"] = Model.Title;
}

<div class="row">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0">@Model.Title</h5>
                <div class="d-flex gap-2">
                    @if (User.IsInRole("Admin") || User.FindFirst(ClaimTypes.NameIdentifier)?.Value == Model.CreatedById.ToString())
                    {
                        <a asp-controller="Tickets" asp-action="Edit" asp-route-id="@Model.TicketId"
                           class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-pencil me-1"></i>Edit
                        </a>

                        <form asp-controller="Tickets" asp-action="Delete" asp-route-id="@Model.TicketId" method="post"
                              class="d-inline" onsubmit="return confirm('Are you sure you want to delete this ticket?')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash me-1"></i>Delete
                            </button>
                        </form>
                    }
                </div>
            </div>
            <div class="card-body">
                <p class="text-muted">@Model.Description</p>
                <hr />
                <div class="row g-3">
                    <div class="col-6">
                        <small class="text-muted d-block">Status</small>
                        <strong class="badge bg-@GetStatusColor(Model.Status.ToString())">
                            @Model.Status
                        </strong>
                    </div>
                    <div class="col-6">
                        <small class="text-muted d-block">Priority</small>
                        <strong class="badge bg-@GetPriorityColor(Model.Priority)">
                            @Model.Priority
                        </strong>
                    </div>
                    <div class="col-6">
                        <small class="text-muted d-block">Category</small>
                        <strong>@Model.CategoryName</strong>
                    </div>
                    <div class="col-6">
                        <small class="text-muted d-block">Assigned To</small>
                        <strong>@(Model.AssignedToName ?? "Unassigned")</strong>
                    </div>
                    <div class="col-6">
                        <small class="text-muted d-block">Created By</small>
                        <strong>@Model.CreatedByName</strong>
                    </div>
                    <div class="col-6">
                        <small class="text-muted d-block">Created</small>
                        <strong>@DateHelper.FormatCairoDate(Model.CreatedAt)</strong>
                    </div>

                    <div class="col-6">
                        <small class="text-muted d-block">Due Date</small>
                        @{
                            bool isBreached = Model.DueDate < DateTime.UtcNow
                                              && Model.Status != TicketStatus.Resolved
                                              && Model.Status != TicketStatus.Closed;

                            <strong class="@(isBreached ? "text-danger" : "")">
                                @DateHelper.FormatCairoDate(Model.DueDate)
                                @if (isBreached)
                                {
                                    <span class="badge bg-danger ms-1">SLA Breached</span>
                                }
                            </strong>
                        }
                    </div>

                    <div class="col-6">
                        <small class="text-muted d-block">Updated</small>
                        <strong>@(Model.UpdatedAt.HasValue ? DateHelper.FormatCairoDate(Model.UpdatedAt.Value) : "Not updated")</strong>
                    </div>

                    <div class="col-6">
                        <small class="text-muted d-block">Resolved</small>
                        <strong>@(Model.ResolvedAt.HasValue ? DateHelper.FormatCairoDate(Model.ResolvedAt.Value) : "Not resolved")</strong>
                    </div>
                </div>
            </div>
        </div>

        @{
            ViewData["TicketId"] = Model.TicketId;
        }
        @await Html.PartialAsync("_CommentsPartial", Model.Comments)

    </div>

    <div class="col-md-4">
        @await Html.PartialAsync("_HistoryPartial", Model.Histories)
    </div>
</div>


@functions {
    string GetPriorityColor(string p) => p switch
    {
        "Critical" => "danger",
        "High" => "warning",
        "Medium" => "info",
        _ => "secondary"
    };

    string GetStatusColor(string s) => s switch
    {
        "Open" => "primary",
        "InProgress" => "warning",
        "Resolved" => "success",
        "Closed" => "secondary",
        _ => "light"
    };
}